# Supabase (required for production on Cloudflare Pages)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: public endpoint for AI proxy (Supabase Edge Function URL or other API)
# Expected POST body: { messages: [{ role, content }] }
# Expected response: { reply: "..." }
VITE_AI_PROXY_URL=
